# Copy to .env and fill in. .env is gitignored -- never commit real secrets.

# Postgres connection string. Defaults to the local docker-compose instance.
# WNBA_ENGINE_DATABASE_URL=postgresql://wnba:wnba@localhost:5434/wnba_engine

# Kalshi market data is readable without a key today; only needed if that changes.
# WNBA_ENGINE_KALSHI_API_KEY=

# Required for any balldontlie call -- paid API, no anonymous tier.
# https://app.balldontlie.io/signup (WNBA + GOAT tier for advanced stats)
WNBA_ENGINE_BALLDONTLIE_API_KEY=
